# ============================================================
# Headwind MDM - Environment Variables Example
# ============================================================
# For Docker/Render deployment.
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env to Git — it contains secrets!
# ============================================================

# ----- Database: PostgreSQL (with SSL) -----
SQL_HOST=pg-3303c292-ommm.g.aivencloud.com
SQL_PORT=28918
SQL_BASE=defaultdb
SQL_USER=avnadmin
SQL_PASS=YOUR_DB_PASSWORD

# ----- Domain & Protocol -----
PROTOCOL=http
BASE_DOMAIN=apkserver-3ur0.onrender.com

# ----- Security -----
SHARED_SECRET=changeme-C3z9vi54

# ----- Optional: Admin email for Let's Encrypt -----
# ADMIN_EMAIL=admin@example.com

# ----- Optional: Force reconfigure on next start -----
# FORCE_RECONFIGURE=true

# ----- Optional: Local IP if behind NAT -----
# LOCAL_IP=172.31.91.82
