# ============================================================
# Headwind MDM - Environment Variables Example
# ============================================================
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env to Git — it contains secrets!
# ============================================================

# ----- Database: PostgreSQL (with SSL) -----
jdbc.driver=org.postgresql.Driver
jdbc.url=jdbc:postgresql://YOUR_HOST:YOUR_PORT/YOUR_DB?sslmode=require
jdbc.username=YOUR_DB_USER
jdbc.password=YOUR_DB_PASSWORD

# ----- Base Directories -----
base.directory=/opt/headwind/data
files.directory=/opt/headwind/files
plugins.files.directory=/opt/headwind/plugins
initialization.completion.signal.file=/opt/headwind/initialized.txt

# ----- Base URL (update after deployment) -----
base.url=https://YOUR_APP.onrender.com

# ----- Usage Scenario -----
usage.scenario=private

# ----- Security -----
secure.enrollment=0
hash.secret=changeme-C3z9vi54
role.orgadmin.id=2
aapt.command=aapt

# ----- MQTT Push Notifications -----
mqtt.server.uri=localhost:31000
mqtt.auth=true
mqtt.message.delay=1000
mqtt.external=0

# ----- Device Search -----
device.fast.search.chars=5

# ----- Plugin: Device Log -----
plugin.devicelog.persistence.config.class=com.hmdm.plugins.devicelog.persistence.postgres.DeviceLogPostgresPersistenceConfiguration

# ----- Plugin: Audit -----
plugin.audit.display.forwarded.ip=false

# ----- Plugin: Photo -----
plugin.photo.enable.places=false

# ----- Logging -----
log4j.config=file:///opt/headwind/log4j-hmdm.xml

# ----- SMTP (Email for password recovery) -----
smtp.host=smtp.mailgun.org
smtp.port=25
smtp.ssl=0
smtp.starttls=0
smtp.username=
smtp.password=
smtp.from=noreply@YOUR_APP.onrender.com

# ----- JWT Configuration -----
jwt.secretkey=YOUR_JWT_SECRET
jwt.validity=86400
jwt.validityrememberme=2592000

# ----- Proxy Settings (if behind a reverse proxy) -----
# proxy.addresses=
# proxy.ip.header=X-Real-IP
